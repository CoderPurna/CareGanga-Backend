model Permission {
  id              String   @id @default(uuid())
  userId          String   @unique
  dashboard       Boolean  @default(false)
  donations       Boolean  @default(false)
  volunteers      Boolean  @default(false)
  campaigns       Boolean  @default(false)
  deleteCampaigns Boolean  @default(false)
  payments        Boolean  @default(false)
  receipts        Boolean  @default(false)
  reports         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
