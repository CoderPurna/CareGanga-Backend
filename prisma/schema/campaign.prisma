model Campaign {
  id           String             @id @default(uuid())
  ngoId        String
  title        String
  slug         String             @unique
  description  String
  goalAmount   Float
  raisedAmount Float              @default(0.0)
  thumbnail    String?
  banner       String?
  status       CampaignStatus     @default(DRAFT)
  startDate    DateTime
  endDate      DateTime
  publishedAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  ngo          NGO                @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  donations    Donation[]
}
