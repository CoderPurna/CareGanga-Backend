model User {
  id            String     @id @default(uuid())
  name          String
  email         String     @unique
  phone         String?    @unique
  password      String
  avatar        String?
  role          Role       @default(USER)
  status        UserStatus @default(ACTIVE)
  emailVerified DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  ngos          NGO[]
}
