model MembershipTier {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  duration    Int
  benefits    String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships            Membership[]
  membershipApplications MembershipApplication[]
}

model Membership {
  id         String           @id @default(uuid())
  ngoId      String?          @unique
  userId     String?          @unique
  tierId     String
  startDate  DateTime         @default(now())
  expiryDate DateTime
  status     MembershipStatus @default(PENDING)
  paymentId  String?

  fullName           String
  dob                DateTime
  gender             String
  mobile             String
  email              String
  permanentAddressId String
  billingAddressId   String
  profileImage       String
  supportingDocument String

  ngo              NGO?           @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  user             User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier             MembershipTier @relation(fields: [tierId], references: [id], onDelete: Restrict)
  permanentAddress Address        @relation("PermanentAddress", fields: [permanentAddressId], references: [id], onDelete: Restrict)
  billingAddress   Address        @relation("BillingAddress", fields: [billingAddressId], references: [id], onDelete: Restrict)
}

model MembershipApplication {
  id          String             @id @default(uuid())
  userId      String?
  ngoId       String?
  tierId      String
  status      MembershipStatus   @default(PENDING)
  remarks     String?
  submittedAt DateTime           @default(now())
  reviewedAt  DateTime?

  fullName           String
  dob                DateTime
  gender             String
  mobile             String
  email              String
  permanentAddressId String
  billingAddressId   String
  profileImage       String
  supportingDocument String

  user             User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  ngo              NGO?           @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  tier             MembershipTier @relation(fields: [tierId], references: [id], onDelete: Restrict)
  permanentAddress Address        @relation("PermanentAddressApp", fields: [permanentAddressId], references: [id], onDelete: Restrict)
  billingAddress   Address        @relation("BillingAddressApp", fields: [billingAddressId], references: [id], onDelete: Restrict)
}
